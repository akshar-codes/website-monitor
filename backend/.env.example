# ─── Server ───
NODE_ENV=development
PORT=5000

# ─── MongoDB ───
MONGO_URI=mongodb://localhost:27017/website-monitor

# ─── Logging ───
# LOG_LEVEL: error | warn | info | http | verbose | debug | silly
# Defaults to "debug" in development and "http" in production if unset.
LOG_LEVEL=debug
# LOG_DIR: absolute or relative path for log files.
# Defaults to backend/logs if unset.
LOG_DIR=

# ─── Rate Limiting ───
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── Redis ───
# Reserved for a future background-queue integration (e.g. BullMQ). Not
# used by sessions — sessions are stored in MongoDB via connect-mongo.
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# ─── Monitoring Worker ───
POLL_TICK_MS=10000
POLL_TIMEOUT_MS=10000
MONITOR_RETRY_COUNT=2
MONITOR_RETRY_DELAY=1000
CONSECUTIVE_FAILURE_THRESHOLD=3

# ─── CORS ───
# Comma-separated whitelist of origins allowed to make credentialed requests,
# e.g. "https://app.example.com,https://admin.example.com"
CORS_ORIGIN=http://localhost:5173

# ─── Request limits ───
# express.json()/urlencoded() body size limit (e.g. "1mb", "500kb").
MAX_BODY_SIZE=1mb

# ─── Reverse proxy ───
# Number of hops to trust for req.ip / X-Forwarded-*. Needed for
# express-rate-limit and secure cookies to see the real client address
# behind a load balancer/reverse proxy. Set to 0 if directly internet-facing.
TRUST_PROXY=1

# ─── Cookies ───
# Signs cookies via cookie-parser, so future auth (Passport session/refresh
# cookies) is tamper-evident. Required — min 32 chars. Generate with:
#   openssl rand -hex 32
COOKIE_SECRET=

# ─── Sessions & Authentication ───
# Signs the session-ID cookie (express-session). Required — min 32 chars.
# Generate with: openssl rand -hex 32
SESSION_SECRET=
# Name of the session cookie.
SESSION_NAME=wm.sid

# Default session lifetime (no "remember me") in milliseconds, and idle
# timeout under the rolling-session model. Defaults to 1 day.
SESSION_DEFAULT_MAX_AGE_MS=86400000
# "Remember me" session lifetime in milliseconds — also the MongoStore
# fallback TTL. Defaults to 30 days.
SESSION_REMEMBER_ME_MAX_AGE_MS=2592000000

# Stricter rate limit applied only to /auth/login, /auth/register, and the
# email-verification endpoints, to slow down credential-stuffing / spam.
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10

# ─── Client / Frontend ───
# Canonical origin of the frontend app — used to build links embedded in
# emails (e.g. the email-verification and password-reset links). Must
# match where the SPA is actually served.
CLIENT_URL=http://localhost:5173

# ─── Email / SMTP ───
# BREAKING CHANGE: the server now fails to start without SMTP configured,
# since account verification email is no longer optional. For local dev,
# point these at a catch-all inbox like Mailtrap, Ethereal, or Mailhog.
SMTP_HOST=
SMTP_PORT=587
# "true" enables implicit TLS (typically port 465). Leave "false" for
# STARTTLS on port 587, which is the common default.
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_FROM_NAME=WebMonitor

# ─── Email Verification ───
# How long an issued verification link stays valid. Defaults to 24 hours.
EMAIL_VERIFICATION_TOKEN_EXPIRES_MS=86400000
# Minimum time between resend requests for the same account. Defaults to 60s.
EMAIL_VERIFICATION_RESEND_COOLDOWN_MS=60000

# ─── Password Reset ───
# How long an issued password-reset link stays valid. Kept short since a
# reset link grants immediate account takeover if intercepted.
# Defaults to 1 hour.
PASSWORD_RESET_TOKEN_EXPIRES_MS=3600000
