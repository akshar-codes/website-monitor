# ─── Server ───
NODE_ENV=development
PORT=5000

# ─── MongoDB ───
MONGO_URI=mongodb://localhost:27017/website-monitor

# ─── Logging ───
# LOG_LEVEL: error | warn | info | http | verbose | debug | silly
# Defaults to "debug" in development and "http" in production if unset.
LOG_LEVEL=debug
# LOG_DIR: absolute or relative path for log files.
# Defaults to backend/logs if unset.
LOG_DIR=

# ─── Rate Limiting ───
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── Redis ───
# Reserved for a Redis-backed session store (e.g. connect-redis, ahead of
# Passport.js authentication) and/or future background-queue integration.
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# ─── Monitoring Worker ───
POLL_TICK_MS=10000
POLL_TIMEOUT_MS=10000
MONITOR_RETRY_COUNT=2
MONITOR_RETRY_DELAY=1000
CONSECUTIVE_FAILURE_THRESHOLD=3

# ─── CORS ───
# Comma-separated whitelist of origins allowed to make credentialed requests,
# e.g. "https://app.example.com,https://admin.example.com"
CORS_ORIGIN=http://localhost:5173

# ─── Request limits ───
# express.json()/urlencoded() body size limit (e.g. "1mb", "500kb").
MAX_BODY_SIZE=1mb

# ─── Reverse proxy ───
# Number of hops to trust for req.ip / X-Forwarded-*. Needed for
# express-rate-limit and secure cookies to see the real client address
# behind a load balancer/reverse proxy. Set to 0 if directly internet-facing.
TRUST_PROXY=1

# ─── Cookies ───
# Signs cookies via cookie-parser, so future auth (Passport session/refresh
# cookies) is tamper-evident. Required — min 32 chars. Generate with:
#   openssl rand -hex 32
COOKIE_SECRET=
